# ─────────────────────────────────────────────────────────────
# Portfolio — Environment Variables
# Copy this file to .env (never commit .env to git)
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string.
# On Replit:  set via the Database integration (auto-provided as DATABASE_URL)
# On Vercel:  use Vercel Postgres → Settings → Environment Variables
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session / Auth ────────────────────────────────────────────
# Secret key used to sign the admin session cookie.
# Generate with:  openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# ── Admin Credentials ────────────────────────────────────────
# Username and password for the admin panel at /admin/login
# Change these before deploying!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Vercel Blob Storage ───────────────────────────────────────
# Required for certificate image/PDF uploads.
# Get this from: Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server Port (development only) ───────────────────────────
# The API server listens on this port in development.
# On Vercel this is handled automatically.
PORT=8080
